rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Saves: apenas o próprio usuário lê/escreve
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Config do app: qualquer usuário autenticado pode ler
    // Escrita permitida para qualquer usuário autenticado (para o botão de force-update funcionar)
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Demais documentos: apenas autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
